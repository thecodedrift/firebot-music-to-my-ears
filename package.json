{
  "name": "firebot-script-music-to-my-ears",
  "version": "1.0.2",
  "private": true,
  "description": "A Firebot custom script adding Spotify song-request and playback effects.",
  "scriptOutputName": "musicToMyEars",
  "main": "dist/musicToMyEars.js",
  "scripts": {
    "build": "webpack --mode=production",
    "build:dev": "webpack --mode=development && pnpm copy",
    "copy": "node scripts/copy-build.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "spotify:auth": "tsx tools/spotify/auth.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "pnpm build && node scripts/release.js",
    "openspec": "openspec"
  },
  "keywords": [
    "firebot",
    "twitch",
    "spotify",
    "song-requests"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@crowbartools/firebot-custom-scripts-types": "^5.65.0",
    "@fission-ai/openspec": "^1.4.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^30.4.2",
    "prettier": "^3.2.0",
    "terser-webpack-plugin": "^5.3.10",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
