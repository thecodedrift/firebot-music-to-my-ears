# Spotify credentials for the local search test harness (tools/spotify/).
# Copy this file to .env and fill in the values from your Spotify app:
#   https://developer.spotify.com/dashboard
#
# These are only used by `pnpm spotify:auth` / `pnpm spotify:search` for local
# debugging. They are NOT used by the Firebot script at runtime (Firebot takes
# client id/secret as script parameters and manages its own OAuth).

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Filled in automatically by `pnpm spotify:auth`. Leave blank initially.
SPOTIFY_REFRESH_TOKEN=

# Optional: OAuth callback used by `pnpm spotify:auth`. Defaults to Firebot's
# already-registered redirect (so no Spotify dashboard change is needed), but
# that port belongs to Firebot — close Firebot before running auth. Override
# only if you've registered a different redirect URI in your Spotify app.
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:7472/api/v1/auth/callback
